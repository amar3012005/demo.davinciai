# ===== Identity =====
ORGANIZATION_NAME=Davinci AI
ORGANIZATION_FULL_NAME=Davinci AI
AGENT_NAME=Tara
AGENT_ID=tara
TENANT_ID=tara

# Optional host-based agent routing suffix (e.g., agent1.company.com -> agent1)
AGENT_HOST_SUFFIX=davinciai.eu

# ===== Public URLs =====
PUBLIC_URL=http://localhost:8004
WIDGET_WS_URL=ws://localhost:8004/ws
ORCHESTRATOR_WS_URL=ws://localhost:8004/ws
GLOBAL_CLIENT_URL=
FORCE_GLOBAL_DOMAIN=false

# ===== Services =====
STT_SERVICE_URL=http://stt:8002
TTS_SERVICE_URL=http://tts:8000
RAG_SERVICE_URL=http://rag:8003
INTENT_SERVICE_URL=http://intent:8002
REDIS_URL=redis://redis:6379/0
DAVINCIAI_BACKEND_URL=

# ===== Runtime =====
SERVER_HOST=0.0.0.0
SERVER_PORT=8004
LOG_LEVEL=INFO
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,de
STREAM_OUT=auto
AUTO_DETECT_LANGUAGE=true

# ===== TTS / Voice =====
CARTESIA_VOICE_ID=
# Optional per-agent voice override pattern:
# VOICE_ID_TARA=your_voice_id

# ===== RAG =====
RAG_STREAM_ENDPOINT=/api/v1/stream_query
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7
RAG_LANGUAGE=english
ENABLE_INCREMENTAL_RAG=true
ENABLE_MAP=false

# ===== Session =====
SESSION_TIMEOUT_SECONDS=30
MAX_TIMEOUT_PROMPTS=2
SESSION_TTL_SECONDS=3600
IGNORE_STT_WHILE_SPEAKING=false

# ===== Ultimate Modules =====
USE_ULTIMATE_TARA=false
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=
