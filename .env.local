# ═══════════════════════════════════════════════════════════
# TARA Ultimate Architecture - Local Development Environment
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and customize for your setup
# cp .env.local .env

# ═══════════════════════════════════════════════════════════
# LLM Configuration (Groq)
# ═══════════════════════════════════════════════════════════
LLM_API_KEY=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
LLM_MODEL=openai/gpt-oss-20b
ANALYTICS_MODEL=qwen/qwen3-32b

# Mind Reader Model (Fast LLM for intent parsing)
MIND_READER_MODEL=llama-3.1-8b-instant

# ═══════════════════════════════════════════════════════════
# Qdrant Configuration (Hive Mind)
# ═══════════════════════════════════════════════════════════
# Option 1: Use cloud Qdrant (recommended for production)
QDRANT_URL=https://878ba705-a90e-44d7-96fc-782399dd97ae.europe-west3-0.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJhY2Nlc3MiOiJtIn0.ao39iukssxR-CapMCzch2RRRPrEWwotD7hnOZZ2L95Q

# Option 2: Use local Qdrant (uncomment below)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

QDRANT_COLLECTION=tara_hive

# ═══════════════════════════════════════════════════════════
# Redis Configuration
# ═══════════════════════════════════════════════════════════
REDIS_URL=redis://redis:6379/0

# ═══════════════════════════════════════════════════════════
# Ultimate TARA Feature Flags
# Set to 'true' to enable, 'false' to disable
# ═══════════════════════════════════════════════════════════
# Enable new semantic detective (hybrid scoring)
USE_NEW_DETECTIVE=true

# Enable mission brain (constraint enforcement)
USE_MISSION_BRAIN=true

# Enable live graph (Redis DOM mirror)
USE_LIVE_GRAPH=true

# Enable hive interface (Qdrant retrieval)
USE_HIVE_INTERFACE=true

# Enable Hive Mind in general
ENABLE_HIVE_MIND=true

# ═══════════════════════════════════════════════════════════
# Widget Configuration (LOCAL DEVELOPMENT)
# ═══════════════════════════════════════════════════════════
# WebSocket URL for browser widget (NO SSL for local)
WIDGET_WS_URL=ws://localhost:8004/ws

# Public URL for the orchestrator
PUBLIC_URL=http://localhost:8004

# Orchestrator WebSocket URL
ORCHESTRATOR_WS_URL=ws://localhost:8004/ws

# ═══════════════════════════════════════════════════════════
# Service URLs (Internal Docker Network)
# ═══════════════════════════════════════════════════════════
RAG_SERVICE_URL=http://rag:8003
STT_SERVICE_URL=http://stt:8002
TTS_SERVICE_URL=http://tts:8000

# ═══════════════════════════════════════════════════════════
# STT Service (Sarvam)
# ═══════════════════════════════════════════════════════════
SARVAM_API_KEY=sk_estz3g3w_AEzxGTk7OV6lmQyE69cIceBI
SARVAM_MODEL=saaras:v2.5

# ═══════════════════════════════════════════════════════════
