# ═══════════════════════════════════════════════════════════
CARTESIA_API_KEY=sk_car_k6RiuJVp2gEzAP6ozyCrdp
CARTESIA_VOICE_ID=07bc462a-c644-49f1-baf7-82d5599131be
CARTESIA_OUTPUT_FORMAT=pcm_f32le
